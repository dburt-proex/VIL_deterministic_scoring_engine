{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VIL Signal Input",
  "type": "object",
  "required": ["source", "content"],
  "properties": {
    "signal_id": {"type": "string"},
    "source": {"type": "string", "minLength": 1},
    "signal_type": {
      "type": "string",
      "enum": ["lead", "rfi", "content", "support", "research", "workflow_request", "other"]
    },
    "content": {"type": "string", "minLength": 1},
    "metadata": {"type": "object"},
    "source_pointers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type": {"type": "string"},
          "value": {"type": "string"}
        }
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
